class Main {
  public static void main(String[] args) {
    System.out.println(42);
    {
      System.out.println(true);
      if (1 < 2) {
        System.out.println(7);
      } else {
        System.out.println(8);
      }
    }
  }
}

class Vetores {
  public int primeiro(int valor) {
    int[] dados;
    dados = new int[3];
    dados[0] = valor;
    return dados[0];
  }

  public int tamanho() {
    int[] dados;
    dados = new int[5];
    return dados.length;
  }
}

class Calculadora extends Vetores {
  public int soma(int x, int y) {
    int z;
    z = x + y;
    return z;
  }
}
